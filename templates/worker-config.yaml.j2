---
apiVersion: kubeadm.k8s.io/v1beta4
kind: JoinConfiguration
caCertPath: /etc/kubernetes/pki/ca.crt
discovery:
  bootstrapToken:
    apiServerEndpoint: '{{ k8s_masters_address[0] }}'
    caCertHashes:
      - {{ k8s_ca_cert_hashes | mandatory }}
    token: '{{ k8s_cluster_token | mandatory }}'
  tlsBootstrapToken: '{{ k8s_cluster_token | mandatory }}'
nodeRegistration:
  criSocket: unix:///var/run/containerd/containerd.sock
  imagePullPolicy: IfNotPresent
  imagePullSerial: true
  kubeletExtraArgs:
  - name: address
    value: '{{ ansible_local.wireguard.vpn_ip }}'
  - name: node-ip
    value: '{{ ansible_local.wireguard.vpn_ip }}'
  - name: node-labels
    value: "{{ k8s_node_labels | dict2items | map('join', '=') | join(',') }},env={{ env }},stage={{ stage }}"
  name: {{ ansible_hostname }}
  taints: 
    {% for taint in k8s_node_taints %}
    - key: "{{ taint.key }}"
      value: "{{ taint.value }}"
      effect: "{{ taint.effect }}"
    {% endfor %}
timeouts:
  controlPlaneComponentHealthCheck: 4m0s
  discovery: 5m0s
  etcdAPICall: 2m0s
  kubeletHealthCheck: 4m0s
  kubernetesAPICall: 1m0s
  tlsBootstrap: 5m0s
  upgradeManifests: 5m0s
